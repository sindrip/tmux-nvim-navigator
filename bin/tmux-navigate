#!/usr/bin/env sh
set -e

case "$1" in
	left)  dir=h; tmux_dir=L; opposite=l; target_spec='{left-of}'   ;;
	down)  dir=j; tmux_dir=D; opposite=k; target_spec='{down-of}'   ;;
	up)    dir=k; tmux_dir=U; opposite=j; target_spec='{up-of}'     ;;
	right) dir=l; tmux_dir=R; opposite=h; target_spec='{right-of}'  ;;
	*) exit 1 ;;
esac

NL='
'
both=$(tmux display-message -p "#{pane_current_command} #{pane_pid} #{@nvim_socket}" \; \
	display-message -t "$target_spec" -p "#{pane_current_command} #{pane_pid} #{@nvim_socket}" 2>/dev/null) || true
info=${both%%"$NL"*}; target_info=${both#*"$NL"}
[ "$target_info" = "$both" ] && target_info=""
pane_cmd=${info%% *}; rest=${info#* }
pane_pid=${rest%% *}; cached_sock=${rest#* }
target_cmd=${target_info%% *}; target_rest=${target_info#* }
target_pid=${target_rest%% *}; target_cached=${target_rest#* }

find_nvim() {
	child=$(pgrep -oP "$1" nvim 2>/dev/null) || true
	if [ -n "$child" ]; then
		find_nvim "$child"
	else
		echo "$1"
	fi
}

nvim_socket() {
	if [ -n "$2" ] && [ -S "$2" ]; then
		echo "$2"
		return
	fi
	_pid=$(pgrep -oP "$1" nvim 2>/dev/null) || return 1
	_pid=$(find_nvim "$_pid")
	# try standard paths (Linux), then lsof (macOS/BSD)
	for _d in "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" /tmp/nvim.*/*/; do
		for _s in "$_d"/nvim."$_pid".* ; do
			[ -S "$_s" ] && _sock="$_s" && break 2
		done
	done
	if [ -z "$_sock" ]; then
		_sock=$(lsof -U -a -p "$_pid" -Fn 2>/dev/null | grep -m1 "^n.*nvim\.${_pid}\.")
		_sock=${_sock#n}
	fi
	[ -n "$_sock" ] || return 1
	echo "$_sock"
}

reposition_target() {
	[ "$target_cmd" != "nvim" ] && return
	sock=$(nvim_socket "$target_pid" "$target_cached") || return
	[ "$sock" != "$target_cached" ] && tmux set-option -p -t "$target_spec" @nvim_socket "$sock"
	nvim --headless --server "$sock" --remote-expr \
		"execute('999wincmd $opposite')" >/dev/null 2>&1 || true
}

navigate_tmux() {
	reposition_target
	tmux select-pane -"$tmux_dir"
}

if [ "$pane_cmd" != "nvim" ]; then
	navigate_tmux
	exit
fi

socket=$(nvim_socket "$pane_pid" "$cached_sock") || { navigate_tmux; exit; }
[ "$socket" != "$cached_sock" ] && tmux set-option -p @nvim_socket "$socket"

# try wincmd in nvim — returns 1 if at edge (winnr unchanged), 0 if moved
at_edge=$(nvim --headless --server "$socket" --remote-expr \
	"execute('let g:_w=winnr()|wincmd $dir').(winnr()==g:_w)" 2>&1) || true

if [ "$at_edge" != "0" ]; then
	if [ -z "$target_cmd" ]; then
		# single pane — wrap within nvim
		nvim --headless --server "$socket" --remote-expr \
			"execute('999wincmd $opposite')" >/dev/null 2>&1 || true
	else
		navigate_tmux
	fi
fi
