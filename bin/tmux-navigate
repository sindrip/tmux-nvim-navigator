#!/usr/bin/env sh
set -e

# Run a command with a timeout in seconds. Kills the process with SIGALRM.
_timeout() { _t=$1; shift; perl -e 'alarm shift; exec @ARGV' -- "$_t" "$@"; }

case "$1" in
	left)  dir=h; tmux_dir=L; opposite=l; target_spec='{left-of}'   ;;
	down)  dir=j; tmux_dir=D; opposite=k; target_spec='{down-of}'   ;;
	up)    dir=k; tmux_dir=U; opposite=j; target_spec='{up-of}'     ;;
	right) dir=l; tmux_dir=R; opposite=h; target_spec='{right-of}'  ;;
	*) exit 1 ;;
esac

NL='
'
both=$(tmux display-message -p "#{pane_current_command} #{pane_pid} #{@nvim_pid} #{@nvim_socket}" \; \
	display-message -t "$target_spec" -p "#{pane_current_command} #{pane_pid} #{@nvim_pid} #{@nvim_socket}" 2>/dev/null) || true
info=${both%%"$NL"*}; target_info=${both#*"$NL"}
[ "$target_info" = "$both" ] && target_info=""
pane_cmd=${info%% *}; rest=${info#* }
pane_pid=${rest%% *}; rest=${rest#* }
cached_nvim_pid=${rest%% *}; cached_sock=${rest#* }
target_cmd=${target_info%% *}; target_rest=${target_info#* }
target_pid=${target_rest%% *}; target_rest=${target_rest#* }
target_cached_pid=${target_rest%% *}; target_cached=${target_rest#* }

# Find the first non-stopped nvim child of a given parent
pgrep_nvim() {
    for _p in $(pgrep -P "$1" nvim 2>/dev/null); do
        case "$(ps -o state= -p "$_p")" in T*) continue ;; esac
        echo "$_p"
        return
    done
    return 1
}

# nvim_socket parent_pid [cached_socket] [cached_nvim_pid]
# Outputs: socket_path\nnvim_pid  (two lines)
nvim_socket() {
	if [ -n "$2" ] && [ -S "$2" ] && [ -n "$3" ]; then
		case "$(ps -o state= -p "$3" 2>/dev/null)" in T*) ;; *)
			printf '%s\n%s' "$2" "$3"; return ;; esac
	fi
	_first=$(pgrep_nvim "$1") || return 1
	_sock=""
	# try standard paths, then lsof (macOS/BSD)
	for _d in "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" "${TMPDIR:-/tmp}" /tmp/nvim.*/*/; do
		for _s in "$_d"/nvim."$_first".* ; do
			[ -S "$_s" ] && _sock="$_s" && break 2
		done
	done
	if [ -z "$_sock" ]; then
		_children=$(pgrep -P "$_first" 2>/dev/null | tr '\n' ',')
		_children=${_children%,}
		_pids=$_first${_children:+,$_children}
		_all=$(_timeout 2 lsof -U -a -p "$_pids" -Fn 2>/dev/null | sed -n 's/^n\(\/.*\)/\1/p')
		for _s in $_all; do
			[ -S "$_s" ] || continue
			case "${_s##*/}" in nvim."$_first".*) _sock="$_s"; break ;; esac
		done
		if [ -z "$_sock" ]; then
			for _s in $_all; do
				[ -S "$_s" ] && _sock="$_s" && break
			done
		fi
	fi
	# fallback: trace the TUI's unix socket to find a detached server (e.g. after :restart)
	if [ -z "$_sock" ]; then
		if [ -d /proc/net ]; then
			# Linux: use ss + /proc/net/unix
			_peer_ino=$(ss -xpn 2>/dev/null \
				| awk -v pid="pid=$_first," '$0 ~ pid {print $8; exit}')
			if [ -n "$_peer_ino" ]; then
				_match=$(awk -v ino="$_peer_ino" '$7 == ino && $8 ~ /nvim\./ {print $8}' /proc/net/unix 2>/dev/null)
				if [ -n "$_match" ] && [ -S "$_match" ]; then
					_sock="$_match"
					_first=$(echo "$_sock" | sed 's/.*nvim\.\([0-9]*\)\..*/\1/')
				fi
			fi
		else
			# macOS: use lsof to match kernel socket addresses
			_peer=$(_timeout 2 lsof -U -a -p "$_first" 2>/dev/null \
				| awk '{for(i=1;i<=NF;i++) if($i ~ /^->0x/) {sub(/^->/, "", $i); print $i; exit}}')
			if [ -n "$_peer" ]; then
				_match=$(_timeout 2 lsof -U -c nvim 2>/dev/null \
					| grep -F "$_peer" | grep -v -- '->')
				_sock=$(echo "$_match" | awk '{print $NF}')
				_first=$(echo "$_match" | awk '{print $2}')
			fi
		fi
	fi
	[ -n "$_sock" ] || return 1
	printf '%s\n%s' "$_sock" "$_first"
}

reposition_target() {
	[ "$target_cmd" != "nvim" ] && return
	_result=$(nvim_socket "$target_pid" "$target_cached" "$target_cached_pid") || return 0
	sock=${_result%%"$NL"*}; _npid=${_result#*"$NL"}
	if [ "$sock" != "$target_cached" ]; then
		tmux set-option -p -t "$target_spec" @nvim_socket "$sock" \; \
			set-option -p -t "$target_spec" @nvim_pid "$_npid"
	fi
	_timeout 1 nvim --headless --server "$sock" --remote-expr \
		"execute('999wincmd $opposite')" >/dev/null 2>&1 || true
}

navigate_tmux() {
	reposition_target
	tmux select-pane -"$tmux_dir"
}

if [ "$pane_cmd" != "nvim" ]; then
	navigate_tmux
	exit
fi

clear_cache() {
	tmux set-option -p -u @nvim_socket \; \
		set-option -p -u @nvim_pid
}

_result=$(nvim_socket "$pane_pid" "$cached_sock" "$cached_nvim_pid") || { navigate_tmux; exit; }
socket=${_result%%"$NL"*}; _npid=${_result#*"$NL"}
if [ "$socket" != "$cached_sock" ]; then
	tmux set-option -p @nvim_socket "$socket" \; \
		set-option -p @nvim_pid "$_npid"
fi

# try wincmd in nvim — returns 1 if at edge (winnr unchanged), 0 if moved
at_edge=$(_timeout 1 nvim --headless --server "$socket" --remote-expr \
	"execute('let g:_w=winnr()|wincmd $dir').(winnr()==g:_w)" 2>&1) || {
	clear_cache
	navigate_tmux
	exit
}

if [ "$at_edge" != "0" ]; then
	if [ -z "$target_cmd" ]; then
		# single pane — wrap within nvim
		_timeout 1 nvim --headless --server "$socket" --remote-expr \
			"execute('999wincmd $opposite')" >/dev/null 2>&1 || true
	else
		navigate_tmux
	fi
fi
